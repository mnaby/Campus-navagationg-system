void addCategory() {
    char name[50];
    printf("\n请输入新分类名称: ");
    scanf("%s", name);
    int newId = catCount > 0 ? categories[catCount-1].id + 1 : 1;
    categories[catCount++] = (Category){newId, ""};
    strcpy(categories[catCount-1].name, name);
    printf("添加成功，分类ID: %d\n", newId);
}

void deleteCategory() {
    int id;
    showAllCategories();
    printf("\n请输入要删除的分类ID: ");
    scanf("%d", &id);
    for (int i = 0; i < placeCount; i++)
        if (places[i].categoryId == id) { printf("删除失败：该分类下还有地点。\n"); return; }
    int index = -1;
    for (int i = 0; i < catCount; i++)
        if (categories[i].id == id) { index = i; break; }
    if (index == -1) { printf("分类不存在。\n"); return; }
    for (int i = index; i < catCount-1; i++) categories[i] = categories[i+1];
    catCount--;
    printf("删除成功。\n");
}

void modifyCategory() {
    int id;
    showAllCategories();
    printf("\n请输入要修改的分类ID: ");
    scanf("%d", &id);
    int index = -1;
    for (int i = 0; i < catCount; i++)
        if (categories[i].id == id) { index = i; break; }
    if (index == -1) { printf("分类不存在。\n"); return; }
    char newName[50];
    printf("请输入新名称: ");
    scanf("%s", newName);
    strcpy(categories[index].name, newName);
    printf("修改成功。\n");
}

void filterByCategory() {
    showAllCategories();
    int catId;
    printf("\n请输入分类ID筛选地点: ");
    scanf("%d", &catId);
    int catExist = 0;
    char catName[50];
    for (int i = 0; i < catCount; i++)
        if (categories[i].id == catId) { catExist = 1; strcpy(catName, categories[i].name); break; }
    if (!catExist) { printf("分类不存在。\n"); return; }
    printf("\n=== %s 下的地点 ===\n", catName);
    for (int i = 0; i < placeCount; i++)
        if (places[i].categoryId == catId)
            printf("ID: %d  名称: %s  距离: %.0f米  热度: %d\n", 
                   places[i].id, places[i].name, places[i].distance, places[i].hot);
}

