        scanf("%d", &choice);
        switch (choice) {
            case 1: showAllPaths(); break;
            case 2: showShortestPath(); break;
            case 0: return;
            default: printf("无效选择。\n");
        }
    }
}

// ==================== 版本6核心：哈希快速查找 ====================
// 字符串哈希函数（BKDR简化版）
unsigned int hashString(char *str) {
    unsigned int hash = 0;
    while (*str) {
        hash = hash * 131 + *str++;
    }
    return hash % HASH_SIZE;
}

// 初始化哈希表
void initHashTable() {
    for (int i = 0; i < HASH_SIZE; i++)
        placeHash.table[i] = NULL;
}

// 插入哈希表
void insertHash(char *key, int placeIndex) {
    unsigned int idx = hashString(key);
    HashNode *newNode = (HashNode*)malloc(sizeof(HashNode));
    strcpy(newNode->key, key);
    newNode->placeIndex = placeIndex;
    newNode->next = placeHash.table[idx];
    placeHash.table[idx] = newNode;
}

// 哈希查找：支持简称模糊匹配
int hashSearch(char *key) {
    unsigned int idx = hashString(key);
    HashNode *p = placeHash.table[idx];
    while (p) {
        if (strstr(p->key, key) != NULL)
            return p->placeIndex;
        p = p->next;
    }
    return -1;
}

// 构建地点哈希索引
void buildPlaceHash() {
    initHashTable();
    for (int i = 0; i < placeCount; i++)
        insertHash(places[i].name, i);
}

