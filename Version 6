// ==================== 版本6：多维度排序+跳转 ====================
int cmpDistanceAsc(const void *a, const void *b) {
    Place *p1 = (Place*)a, *p2 = (Place*)b;
    return (p1->distance > p2->distance) - (p1->distance < p2->distance);
}
int cmpDistanceDesc(const void *a, const void *b) {
    Place *p1 = (Place*)a, *p2 = (Place*)b;
    return (p2->distance > p1->distance) - (p2->distance < p1->distance);
}
int cmpHotAsc(const void *a, const void *b) {
    return ((Place*)a)->hot - ((Place*)b)->hot;
}
int cmpHotDesc(const void *a, const void *b) {
    return ((Place*)b)->hot - ((Place*)a)->hot;
}

char* getHotLevel(int hot) {
    if (hot >= 10) return "🔥 高热度";
    else if (hot >= 3) return "⭐ 中热度";
    else return "💡 低热度";
}

// 排序结果展示+跳转
void showSortedWithJump(Place sorted[], int n) {
    printf("\n%-4s %-15s %-10s %-8s %s\n", "序号", "名称", "距离(米)", "热度", "热度等级");
    printf("------------------------------------------------\n");
    for (int i = 0; i < n; i++) {
        printf("%-4d %-15s %-10.0f %-8d %s\n", 
               i+1, sorted[i].name, sorted[i].distance, 
               sorted[i].hot, getHotLevel(sorted[i].hot));
    }
    
    int choice;
    printf("\n输入序号跳转至对应地点（输入0返回）: ");
    scanf("%d", &choice);
    if (choice == 0) return;
    if (choice < 1 || choice > n) {
        printf("无效序号。\n");
        return;
    }
    browsePlace(sorted[choice-1].id);
}

void sortMenu() {
    int choice;
    while (1) {
        printf("\n--- 多维度自定义排序 ---\n");
        printf("1. 按距离从近到远\n2. 按距离从远到近\n");
        printf("3. 按热度从高到低\n4. 按热度从低到高\n");
        printf("0. 返回主菜单\n请选择: ");
        scanf("%d", &choice);
        
        Place temp[MAX_PLACE];
        memcpy(temp, places, sizeof(places));
        
        switch (choice) {
            case 1: 
                qsort(temp, placeCount, sizeof(Place), cmpDistanceAsc);
                showSortedWithJump(temp, placeCount);
                break;
            case 2:
                qsort(temp, placeCount, sizeof(Place), cmpDistanceDesc);
                showSortedWithJump(temp, placeCount);
                break;
            case 3:
                qsort(temp, placeCount, sizeof(Place), cmpHotDesc);
                showSortedWithJump(temp, placeCount);
                break;
            case 4:
                qsort(temp, placeCount, sizeof(Place), cmpHotAsc);
                showSortedWithJump(temp, placeCount);
                break;
            case 0: return;
            default: printf("无效选择。\n");
        }
    }
}

