// ==================== 栈操作 ====================
void initStack() { historyStack.top = -1; }
void pushStack(int placeId) {
    if (historyStack.top < MAX_HISTORY - 1)
        historyStack.placeIds[++historyStack.top] = placeId;
}
int popStack() {
    if (historyStack.top == -1) return -1;
    return historyStack.placeIds[historyStack.top--];
}

// ==================== 队列操作 ====================
void initQueue() {
    recentQueue.front = 0;
    recentQueue.rear = 0;
    recentQueue.size = 0;
}
void enqueueRecent(int placeId) {
    // 已存在则移至队尾
    int exist = -1;
    for (int i = 0; i < recentQueue.size; i++) {
        int idx = (recentQueue.front + i) % MAX_RECENT;
        if (recentQueue.placeIds[idx] == placeId) { exist = i; break; }
    }
    if (exist != -1) {
        for (int i = exist; i < recentQueue.size - 1; i++) {
            int idx = (recentQueue.front + i) % MAX_RECENT;
            int nextIdx = (recentQueue.front + i + 1) % MAX_RECENT;
            recentQueue.placeIds[idx] = recentQueue.placeIds[nextIdx];
        }
        recentQueue.rear = (recentQueue.rear - 1 + MAX_RECENT) % MAX_RECENT;
        recentQueue.size--;
    }
    // 队满则移除最早访问
    if (recentQueue.size == MAX_RECENT) {
        recentQueue.front = (recentQueue.front + 1) % MAX_RECENT;
        recentQueue.size--;
    }
    recentQueue.placeIds[recentQueue.rear] = placeId;
    recentQueue.rear = (recentQueue.rear + 1) % MAX_RECENT;
    recentQueue.size++;
}

// ==================== 基础工具函数 ====================
char* getPlaceName(int placeId) {
    for (int i = 0; i < placeCount; i++)
        if (places[i].id == placeId) return places[i].name;
    return "未知地点";
}

int getPlaceIndex(int placeId) {
    for (int i = 0; i < placeCount; i++)
        if (places[i].id == placeId) return i;
    return -1;
}

// 浏览地点（热度+1，记录历史）
void browsePlace(int placeId) {
    int idx = getPlaceIndex(placeId);
    if (idx == -1) { printf("地点不存在。\n"); return; }
    
    if (currentPlaceId != -1) pushStack(currentPlaceId);
    currentPlaceId = placeId;
    places[idx].hot++;
    enqueueRecent(placeId);
    printf("\n当前位置：%s  距离: %.0f米  热度: %d\n", 
           places[idx].name, places[idx].distance, places[idx].hot);
}

// 历史后退
void goBack() {
    int prevId = popStack();
    if (prevId == -1) { printf("没有可后退的历史记录。\n"); return; }
    currentPlaceId = prevId;
    printf("后退成功，当前位置：%s\n", getPlaceName(prevId));
}

// 展示最近访问
void showRecentPlaces() {
    printf("\n=== 最近访问的地点（共%d个）===\n", recentQueue.size);
    if (recentQueue.size == 0) { printf("暂无记录。\n"); return; }
    for (int i = recentQueue.size - 1; i >= 0; i--) {
        int idx = (recentQueue.front + i) % MAX_RECENT;
        printf("%d. %s\n", recentQueue.size - i, getPlaceName(recentQueue.placeIds[idx]));
    }
}

// 从最近访问跳转
void jumpFromRecent() {
    showRecentPlaces();
    if (recentQueue.size == 0) return;
    int num;
    printf("请输入序号跳转（输入0取消）: ");
    scanf("%d", &num);
    if (num == 0) return;
    if (num < 1 || num > recentQueue.size) { printf("无效序号。\n"); return; }
    int idx = (recentQueue.front + (recentQueue.size - num)) % MAX_RECENT;
    browsePlace(recentQueue.placeIds[idx]);
}

// ==================== KMP模糊搜索 ====================
int naiveMatch(char *text, char *pattern, int *pos) {
    int n = strlen(text), m = strlen(pattern);
    int count = 0;
    for (int i = 0; i <= n - m; i++) {
        int j;
        for (j = 0; j < m; j++)
            if (text[i+j] != pattern[j]) break;
        if (j == m) pos[count++] = i + 1;
    }
    return count;
}

void getNext(char *pattern, int *next) {
    int m = strlen(pattern);
    next[0] = -1;
    int i = 0, j = -1;
    while (i < m) {
        if (j == -1 || pattern[i] == pattern[j]) {
            i++; j++;
            next[i] = j;
        } else j = next[j];
    }
}

int kmpMatch(char *text, char *pattern, int *pos) {
    int n = strlen(text), m = strlen(pattern);
    int next[m+1];
    getNext(pattern, next);
    int count = 0, i = 0, j = 0;
    while (i < n) {
        if (j == -1 || text[i] == pattern[j]) {
            i++; j++;
        } else j = next[j];
        if (j == m) {
            pos[count++] = i - j + 1;
            j = next[j];
        }
    }
    return count;
}

void searchPlaces() {
    char keyword[50];
    printf("\n请输入搜索关键词: ");
    scanf("%s", keyword);
    int pos[50];
    int naiveTotal = 0, kmpTotal = 0;
    
    printf("\n--- 朴素匹配结果 ---\n");
    clock_t start1 = clock();
    for (int i = 0; i < placeCount; i++) {
        int cnt = naiveMatch(places[i].name, keyword, pos);
        if (cnt > 0) {
            printf("地点: %-15s 匹配位置: ", places[i].name);
            for (int k = 0; k < cnt; k++) printf("%d ", pos[k]);
            printf("\n");
            naiveTotal += cnt;
        }
    }
    clock_t end1 = clock();
    if (naiveTotal == 0) printf("未找到匹配地点。\n");
    printf("总匹配数: %d  耗时: %.2f ms\n", naiveTotal, (double)(end1-start1)/CLOCKS_PER_SEC*1000);
    
    printf("\n--- KMP匹配结果 ---\n");
    clock_t start2 = clock();
    for (int i = 0; i < placeCount; i++) {
        int cnt = kmpMatch(places[i].name, keyword, pos);
        if (cnt > 0) {
            printf("地点: %-15s 匹配位置: ", places[i].name);
            for (int k = 0; k < cnt; k++) printf("%d ", pos[k]);
            printf("\n");
            kmpTotal += cnt;
        }
    }
    clock_t end2 = clock();
    if (kmpTotal == 0) printf("未找到匹配地点。\n");
    printf("总匹配数: %d  耗时: %.2f ms\n", kmpTotal, (double)(end2-start2)/CLOCKS_PER_SEC*1000);
}

// ==================== 图与路径规划 ====================
void initGraph() {
    graph.vertexNum = placeCount;
    for (int i = 0; i < MAX_PLACE; i++) {
        for (int j = 0; j < MAX_PLACE; j++)
            graph.edges[i][j] = INF;
        graph.edges[i][i] = 0;
    }
    
    // 地点下标对应：0-第一教学楼 1-图书馆 2-实验楼 3-学生食堂 4-学生宿舍 5-超市 6-体育馆 7-田径场
    graph.edges[0][1] = 150; graph.edges[1][0] = 150;
    graph.edges[0][3] = 100; graph.edges[3][0] = 100;
    graph.edges[1][2] = 200; graph.edges[2][1] = 200;
    graph.edges[3][5] = 50;  graph.edges[5][3] = 50;
    graph.edges[3][4] = 300; graph.edges[4][3] = 300;
    graph.edges[4][7] = 200; graph.edges[7][4] = 200;
    graph.edges[6][7] = 100; graph.edges[7][6] = 100;
    graph.edges[1][6] = 180; graph.edges[6][1] = 180;
}

// DFS遍历所有可达路径
void dfsAllPaths(int start, int end, int path[], int visited[], int step) {
    path[step] = start;
    visited[start] = 1;
    
    if (start == end) {
        pathCount++;
        printf("路径%d: ", pathCount);
        double totalLen = 0;
        for (int i = 0; i <= step; i++) {
            printf("%s", places[path[i]].name);
            if (i < step) {
                totalLen += graph.edges[path[i]][path[i+1]];
                printf(" → ");
            }
        }
        printf("  总距离: %.0f米\n", totalLen);
        visited[start] = 0;
        return;
    }
    
    for (int i = 0; i < graph.vertexNum; i++) {
        if (!visited[i] && graph.edges[start][i] < INF)
            dfsAllPaths(i, end, path, visited, step + 1);
    }
    visited[start] = 0;
}

void showAllPaths() {
    int startId, endId;
    printf("\n请输入起点地点ID: ");
    scanf("%d", &startId);
    printf("请输入终点地点ID: ");
    scanf("%d", &endId);
    
    int startIdx = getPlaceIndex(startId);
    int endIdx = getPlaceIndex(endId);
    if (startIdx == -1 || endIdx == -1) {
        printf("地点ID无效。\n");
        return;
    }
    
    int path[MAX_PLACE], visited[MAX_PLACE] = {0};
    pathCount = 0;
    printf("\n=== %s → %s 所有可达路径 ===\n", places[startIdx].name, places[endIdx].name);
    dfsAllPaths(startIdx, endIdx, path, visited, 0);
    if (pathCount == 0) printf("两点之间无可达路径。\n");
}

// Dijkstra最短路径算法
void dijkstra(int start, int dist[], int prev[]) {
    int visited[MAX_PLACE] = {0};
    for (int i = 0; i < graph.vertexNum; i++) {
        dist[i] = graph.edges[start][i];
        prev[i] = start;
    }
    dist[start] = 0;
    visited[start] = 1;
    
    for (int i = 0; i < graph.vertexNum - 1; i++) {
        double min = INF;
        int u = -1;
        for (int j = 0; j < graph.vertexNum; j++) {
            if (!visited[j] && dist[j] < min) {
                min = dist[j];
                u = j;
            }
        }
        if (u == -1) break;
        visited[u] = 1;
        // 松弛操作
        for (int j = 0; j < graph.vertexNum; j++) {
            if (!visited[j] && graph.edges[u][j] < INF) {
                if (dist[j] > dist[u] + graph.edges[u][j]) {
                    dist[j] = dist[u] + graph.edges[u][j];
                    prev[j] = u;
                }
            }
        }
    }
}

void showShortestPath() {
    int startId, endId;
    printf("\n请输入起点地点ID: ");
    scanf("%d", &startId);
    printf("请输入终点地点ID: ");
    scanf("%d", &endId);
    
    int startIdx = getPlaceIndex(startId);
    int endIdx = getPlaceIndex(endId);
    if (startIdx == -1 || endIdx == -1) {
        printf("地点ID无效。\n");
        return;
    }
    
    int dist[MAX_PLACE], prev[MAX_PLACE];
    dijkstra(startIdx, dist, prev);
    
    if (dist[endIdx] >= INF) {
        printf("两点之间无可达路径。\n");
        return;
    }
    
    printf("\n=== 最短路径推荐 ===\n");
    printf("总距离: %.0f米\n路径: ", dist[endIdx]);
    
    // 逆序还原路径
    int stack[MAX_PLACE], top = -1;
    int cur = endIdx;
    while (cur != startIdx) {
        stack[++top] = cur;
        cur = prev[cur];
    }
    stack[++top] = startIdx;
    
    while (top >= 0) {
        printf("%s", places[stack[top]].name);
        top--;
        if (top >= 0) printf(" → ");
    }
    printf("\n");
}

