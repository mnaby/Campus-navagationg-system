#include <iostream>
#include <cstring>
#include <algorithm>
#include <ctime>
using namespace std;

const int MAX_LOC = 30;
const int MAX_CAT = 10;
const int NAME_LEN = 20;
const int MAX_HISTORY = 30;
const int MAX_RECENT = 5;
const int INF = 0x3f3f3f3f;

// 分类
struct Category {
    int id;
    char name[NAME_LEN];
};

// 地点
struct Location {
    int id;
    char name[NAME_LEN];
    int category_id;
    int hot;         // 访问热度
    int dist;        // 距离参考点距离
};

// 地点顺序表
struct LocationList {
    Location data[MAX_LOC];
    int length;
};

// 分类顺序表
struct CategoryList {
    Category data[MAX_CAT];
    int length;
};

// 浏览历史栈
struct HistoryStack {
    Location data[MAX_HISTORY];
    int top;
};

// 最近访问队列
struct RecentQueue {
    Location data[MAX_RECENT];
    int front;
    int rear;
    int count;
};

// ==================== V5新增：校园图（邻接矩阵） ====================
struct CampusGraph {
    int edge[MAX_LOC][MAX_LOC];  // 邻接矩阵存储边权
    int nodeNum;                 // 节点总数
};

// 函数前置声明（解决编译依赖问题）
const Location* findLocationById(const LocationList &list, int id);

// 初始化图：自身距离为0，其余初始化为无穷大
void initGraph(CampusGraph &g, int n) {
    g.nodeNum = n;
    for (int i = 1; i <= n; i++) {
        for (int j = 1; j <= n; j++) {
            g.edge[i][j] = (i == j) ? 0 : INF;
        }
    }
}

// 添加双向路径（无向带权图）
void addPath(CampusGraph &g, int a, int b, int len) {
    g.edge[a][b] = len;
    g.edge[b][a] = len;
}

// Dijkstra 单源最短路径算法 + 路径回溯
void dijkstra(const CampusGraph &g, const LocationList &list, int startId, int endId) {
    // 合法性校验
    const Location *startLoc = findLocationById(list, startId);
    const Location *endLoc = findLocationById(list, endId);
    if (!startLoc || !endLoc) {
        cout << "\n错误：起点或终点ID不存在！" << endl;
        return;
    }

    int dist[MAX_LOC], vis[MAX_LOC] = {0};
    int pre[MAX_LOC];  // 前驱数组，记录最短路径的上一个节点
    // 初始化距离与前驱
    for (int i = 1; i <= g.nodeNum; i++) {
        dist[i] = g.edge[startId][i];
        pre[i] = -1;
        if (g.edge[startId][i] != INF && i != startId) {
            pre[i] = startId;
        }
    }
    dist[startId] = 0;
    vis[startId] = 1;

    // 贪心策略：n-1次松弛操作
    for (int i = 2; i <= g.nodeNum; i++) {
        // 选取未访问的距离最小节点
        int minDist = INF, u = -1;
        for (int j = 1; j <= g.nodeNum; j++) {
            if (!vis[j] && dist[j] < minDist) {
                minDist = dist[j];
                u = j;
            }
        }
        if (u == -1) break;  // 剩余节点均不可达
        vis[u] = 1;

        // 松弛相邻节点
        for (int v = 1; v <= g.nodeNum; v++) {
            if (!vis[v] && g.edge[u][v] != INF && dist[v] > dist[u] + g.edge[u][v]) {
                dist[v] = dist[u] + g.edge[u][v];
                pre[v] = u;
            }
        }
    }

    // 输出结果
    cout << "\n===== 最短路径查询结果 =====" << endl;
    cout << "起点：" << startLoc->name << "（ID:" << startId << "）" << endl;
    cout << "终点：" << endLoc->name << "（ID:" << endId << "）" << endl;
    
    if (dist[endId] == INF) {
        cout << "两点之间无可达路径" << endl;
        return;
    }
    cout << "最短总距离：" << dist[endId] << " 米" << endl;

    // 回溯完整路径
    int path[MAX_LOC], cnt = 0;
    for (int cur = endId; cur != -1; cur = pre[cur]) {
        path[cnt++] = cur;
    }

    // 逆序输出路线
    cout << "行走路线：";
    for (int i = cnt - 1; i >= 0; i--) {
        const Location *loc = findLocationById(list, path[i]);
        cout << loc->name;
        if (i > 0) cout << " → ";
    }
    cout << endl;
}
