// ==================== 主函数 ====================
int main() {
    LocationList locList;
    CategoryList catList;
    HistoryStack history;
    RecentQueue recent;
    CampusGraph graph;

    // 初始化数据结构
    initLocList(locList);
    initCatList(catList);
    initHistoryStack(history);
    initRecentQueue(recent);

    // 初始化分类
    addCategory(catList, 1, "教学楼");
    addCategory(catList, 2, "食堂");
    addCategory(catList, 3, "宿舍");
    addCategory(catList, 4, "图书馆");
    addCategory(catList, 5, "操场");

    // 初始化地点（与图节点ID一一对应）
    addLocation(locList, 1, "一号教学楼", 1);
    addLocation(locList, 2, "二号教学楼", 1);
    addLocation(locList, 3, "第一食堂", 2);
    addLocation(locList, 4, "第二食堂", 2);
    addLocation(locList, 5, "男生宿舍", 3);
    addLocation(locList, 6, "女生宿舍", 3);
    addLocation(locList, 7, "中心图书馆", 4);
    addLocation(locList, 8, "主操场", 5);
    addLocation(locList, 9, "行政楼", 1);
    addLocation(locList, 10, "校园大门", 1);

    // 构建校园道路网络
    initGraph(graph, 10);
    addPath(graph, 1, 2, 50);
    addPath(graph, 1, 3, 100);
    addPath(graph, 1, 10, 80);
    addPath(graph, 2, 4, 70);
    addPath(graph, 2, 7, 120);
    addPath(graph, 3, 5, 60);
    addPath(graph, 4, 6, 60);
    addPath(graph, 5, 7, 90);
    addPath(graph, 6, 7, 80);
    addPath(graph, 7, 8, 150);
    addPath(graph, 8, 9, 100);
    addPath(graph, 9, 10, 70);

    int choice;
    while (true) {
        showMenu();
        cin >> choice;
        if (choice == 0) {
            cout << "系统已退出，欢迎下次使用！" << endl;
            break;
        }
        switch (choice) {
            case 1:
                printAllLocations(locList);
                break;
            case 2: {
                int catId;
                cout << "输入分类ID（1-5）：";
                cin >> catId;
                filterByCategory(locList, catList, catId);
                break;
            }
            case 3: {
                int id;
                cout << "输入地点ID：";
                cin >> id;
                visitLocation(history, recent, locList, id);
                break;
            }
            case 4:
                printHistory(history);
                break;
            case 5:
                printRecent(recent);
                break;
            case 6: {
                char key[NAME_LEN];
                cout << "输入关键词：";
                cin >> key;
                searchLocationWithAlgo(locList, key, 0);
                break;
            }
            case 7: {
                char key[NAME_LEN];
                cout << "输入关键词：";
                cin >> key;
                searchLocationWithAlgo(locList, key, 1);
                break;
            }
            case 8: {
                int s, e;
                cout << "输入起点ID："; cin >> s;
                cout << "输入终点ID："; cin >> e;
                dijkstra(graph, locList, s, e);
                break;
            }
            case 9:
                sortByHot(locList);
                printAllLocations(locList);
                break;
            case 10:
                sortByDistance(locList);
                printAllLocations(locList);
                break;
            case 11: {
                int id, d;
                cout << "输入地点ID："; cin >> id;
                cout << "输入距离值："; cin >> d;
                setDistance(locList, id, d);
                break;
            }
            default:
                cout << "输入无效，请重新输入！" << endl;
        }
    }
    return 0;
}
