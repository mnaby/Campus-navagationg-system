struct LocationList {
    Location data[MAX_LOC];
    int length;
};

// 分类顺序表
struct CategoryList {
    Category data[MAX_CAT];
    int length;
};

// 浏览历史栈
struct HistoryStack {
    Location data[MAX_HISTORY];
    int top;
};

// 最近访问队列
struct RecentQueue {
    Location data[MAX_RECENT];
    int front;
    int rear;
    int count;
};

// ==================== 新增：校园图结构 ====================
struct CampusGraph {
    int edge[MAX_LOC][MAX_LOC];  // 邻接矩阵
    int nodeNum;                  // 节点数量
};

