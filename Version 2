#include <stdio.h>
#include <string.h>

#define MAX_CATEGORY 20
#define MAX_PLACE 50
#define MAX_HISTORY 100
#define MAX_RECENT 5

typedef struct {
    int id;
    char name[50];
} Category;

typedef struct {
    int id;
    char name[50];
    int categoryId;
} Place;

// 浏览历史栈（后进先出，用于后退）
typedef struct {
    int placeIds[MAX_HISTORY];
    int top;
} HistoryStack;

// 最近访问队列（先进先出，容量5）
typedef struct {
    int placeIds[MAX_RECENT];
    int front;
    int rear;
    int size;
} RecentQueue;

Category categories[MAX_CATEGORY];
int catCount = 0;
Place places[MAX_PLACE];
int placeCount = 0;
HistoryStack historyStack;
RecentQueue recentQueue;
int currentPlaceId = -1; // 当前所在地点

// 栈操作
void initStack() { historyStack.top = -1; }
void pushStack(int placeId) {
    if (historyStack.top < MAX_HISTORY - 1)
        historyStack.placeIds[++historyStack.top] = placeId;
}
int popStack() {
    if (historyStack.top == -1) return -1;
    return historyStack.placeIds[historyStack.top--];
}

// 队列操作
void initQueue() {
    recentQueue.front = 0;
    recentQueue.rear = 0;
    recentQueue.size = 0;
}
void enqueueRecent(int placeId) {
    // 已存在则移到队尾（最新）
    int exist = -1;
    for (int i = 0; i < recentQueue.size; i++) {
        int idx = (recentQueue.front + i) % MAX_RECENT;
        if (recentQueue.placeIds[idx] == placeId) { exist = i; break; }
    }
    if (exist != -1) {
        for (int i = exist; i < recentQueue.size - 1; i++) {
            int idx = (recentQueue.front + i) % MAX_RECENT;
            int nextIdx = (recentQueue.front + i + 1) % MAX_RECENT;
            recentQueue.placeIds[idx] = recentQueue.placeIds[nextIdx];
        }
        recentQueue.rear = (recentQueue.rear - 1 + MAX_RECENT) % MAX_RECENT;
        recentQueue.size--;
    }
    // 满则出队最早的
    if (recentQueue.size == MAX_RECENT) {
        recentQueue.front = (recentQueue.front + 1) % MAX_RECENT;
        recentQueue.size--;
    }
    recentQueue.placeIds[recentQueue.rear] = placeId;
    recentQueue.rear = (recentQueue.rear + 1) % MAX_RECENT;
    recentQueue.size++;
}

// 根据ID获取地点名称
char* getPlaceName(int placeId) {
    for (int i = 0; i < placeCount; i++)
        if (places[i].id == placeId) return places[i].name;
    return "未知地点";
}

// 浏览地点
void browsePlace(int placeId) {
    int exist = 0;
    for (int i = 0; i < placeCount; i++)
        if (places[i].id == placeId) { exist = 1; break; }
    if (!exist) { printf("地点不存在。\n"); return; }
    
    if (currentPlaceId != -1) pushStack(currentPlaceId);
    currentPlaceId = placeId;
    enqueueRecent(placeId);
    printf("\n当前位置：%s\n", getPlaceName(placeId));
}

// 历史后退
void goBack() {
    int prevId = popStack();
    if (prevId == -1) { printf("没有可后退的历史记录。\n"); return; }
    currentPlaceId = prevId;
    printf("后退成功，当前位置：%s\n", getPlaceName(prevId));
}

// 显示最近访问
void showRecentPlaces() {
    printf("\n=== 最近访问的地点（共%d个）===\n", recentQueue.size);
    if (recentQueue.size == 0) { printf("暂无记录。\n"); return; }
    for (int i = recentQueue.size - 1; i >= 0; i--) {
        int idx = (recentQueue.front + i) % MAX_RECENT;
        printf("%d. %s\n", recentQueue.size - i, getPlaceName(recentQueue.placeIds[idx]));
    }
}

// 从最近访问跳转
void jumpFromRecent() {
    showRecentPlaces();
    if (recentQueue.size == 0) return;
    int num;
    printf("请输入序号跳转（输入0取消）: ");
    scanf("%d", &num);
    if (num == 0) return;
    if (num < 1 || num > recentQueue.size) { printf("无效序号。\n"); return; }
    int idx = (recentQueue.front + (recentQueue.size - num)) % MAX_RECENT;
    browsePlace(recentQueue.placeIds[idx]);
}

// ========== 以下复用版本1基础功能 ==========
void initData() {
    categories[catCount++] = (Category){1, "教学区"};
    categories[catCount++] = (Category){2, "生活区"};
    categories[catCount++] = (Category){3, "运动区"};
    places[placeCount++] = (Place){1, "第一教学楼", 1};
    places[placeCount++] = (Place){2, "图书馆", 1};
    places[placeCount++] = (Place){3, "实验楼", 1};
    places[placeCount++] = (Place){4, "学生食堂", 2};
    places[placeCount++] = (Place){5, "学生宿舍", 2};
    places[placeCount++] = (Place){6, "超市", 2};
    places[placeCount++] = (Place){7, "体育馆", 3};
    places[placeCount++] = (Place){8, "田径场", 3};
}

void browsePlaceMenu() {
    showAllPlaces();
    int id;
    printf("\n请输入地点ID进行浏览（输入0取消）: ");
    scanf("%d", &id);
    if (id == 0) return;
    browsePlace(id);
}

void showAllCategories() {
    printf("\n=== 所有分类 ===\n");
    for (int i = 0; i < catCount; i++)
        printf("ID: %d  名称: %s\n", categories[i].id, categories[i].name);
}

void showAllPlaces() {
    printf("\n=== 所有地点 ===\n");
    for (int i = 0; i < placeCount; i++) {
        char catName[50] = "未知分类";
        for (int j = 0; j < catCount; j++)
            if (categories[j].id == places[i].categoryId) {
                strcpy(catName, categories[j].name);
                break;
            }
        printf("ID: %d  名称: %-15s  分类: %s\n", places[i].id, places[i].name, catName);
    }
}

void addCategory() {
    char name[50];
    printf("\n请输入新分类名称: ");
    scanf("%s", name);
    int newId = catCount > 0 ? categories[catCount-1].id + 1 : 1;
    categories[catCount++] = (Category){newId, ""};
    strcpy(categories[catCount-1].name, name);
    printf("添加成功，分类ID: %d\n", newId);
}

void deleteCategory() {
    int id;
    showAllCategories();
    printf("\n请输入要删除的分类ID: ");
    scanf("%d", &id);
    for (int i = 0; i < placeCount; i++)
        if (places[i].categoryId == id) { printf("删除失败：该分类下还有地点。\n"); return; }
    int index = -1;
    for (int i = 0; i < catCount; i++)
        if (categories[i].id == id) { index = i; break; }
    if (index == -1) { printf("分类不存在。\n"); return; }
    for (int i = index; i < catCount-1; i++) categories[i] = categories[i+1];
    catCount--;
    printf("删除成功。\n");
}

void modifyCategory() {
    int id;
    showAllCategories();
    printf("\n请输入要修改的分类ID: ");
    scanf("%d", &id);
    int index = -1;
    for (int i = 0; i < catCount; i++)
        if (categories[i].id == id) { index = i; break; }
    if (index == -1) { printf("分类不存在。\n"); return; }
    char newName[50];
    printf("请输入新名称: ");
    scanf("%s", newName);
    strcpy(categories[index].name, newName);
    printf("修改成功。\n");
}

void filterByCategory() {
    showAllCategories();
    int catId;
    printf("\n请输入分类ID筛选地点: ");
    scanf("%d", &catId);
    int catExist = 0;
    char catName[50];
    for (int i = 0; i < catCount; i++)
        if (categories[i].id == catId) { catExist = 1; strcpy(catName, categories[i].name); break; }
    if (!catExist) { printf("分类不存在。\n"); return; }
    printf("\n=== %s 下的地点 ===\n", catName);
    for (int i = 0; i < placeCount; i++)
        if (places[i].categoryId == catId)
            printf("ID: %d  名称: %s\n", places[i].id, places[i].name);
}

void categoryMenu() {
    int choice;
    while (1) {
        printf("\n--- 分类管理 ---\n");
        printf("1. 查看所有分类\n2. 添加分类\n3. 删除分类\n");
        printf("4. 修改分类名称\n5. 按分类筛选地点\n0. 返回主菜单\n");
        printf("请选择: ");
        scanf("%d", &choice);
        switch (choice) {
            case 1: showAllCategories(); break;
            case 2: addCategory(); break;
            case 3: deleteCategory(); break;
            case 4: modifyCategory(); break;
            case 5: filterByCategory(); break;
            case 0: return;
            default: printf("无效选择。\n");
        }
    }
}

void mainMenu() {
    int choice;
    while (1) {
        printf("\n===== 校园导航系统 版本2 =====\n");
        if (currentPlaceId != -1) printf("当前位置: %s\n", getPlaceName(currentPlaceId));
        printf("1. 查看所有地点并浏览\n2. 分类管理\n3. 浏览历史后退\n");
        printf("4. 查看最近访问\n5. 从最近访问跳转\n0. 退出系统\n");
        printf("请选择功能: ");
        scanf("%d", &choice);
        switch (choice) {
            case 1: browsePlaceMenu(); break;
            case 2: categoryMenu(); break;
            case 3: goBack(); break;
            case 4: showRecentPlaces(); break;
            case 5: jumpFromRecent(); break;
            case 0: printf("退出系统。\n"); return;
            default: printf("无效输入，请重新选择。\n");
        }
    }
}

int main() {
    initData();
    initStack();
    initQueue();
    mainMenu();
    return 0;
}