#include <stdio.h>
#include <string.h>

#define MAX_CATEGORY 20
#define MAX_PLACE 50

// 分类结构体
typedef struct {
    int id;
    char name[50];
} Category;

// 地点结构体
typedef struct {
    int id;
    char name[50];
    int categoryId;
} Place;

Category categories[MAX_CATEGORY];
int catCount = 0;
Place places[MAX_PLACE];
int placeCount = 0;

// 初始化默认数据
void initData() {
    categories[catCount++] = (Category){1, "教学区"};
    categories[catCount++] = (Category){2, "生活区"};
    categories[catCount++] = (Category){3, "运动区"};

    places[placeCount++] = (Place){1, "第一教学楼", 1};
    places[placeCount++] = (Place){2, "图书馆", 1};
    places[placeCount++] = (Place){3, "实验楼", 1};
    places[placeCount++] = (Place){4, "学生食堂", 2};
    places[placeCount++] = (Place){5, "学生宿舍", 2};
    places[placeCount++] = (Place){6, "超市", 2};
    places[placeCount++] = (Place){7, "体育馆", 3};
    places[placeCount++] = (Place){8, "田径场", 3};
}

// 显示所有分类
void showAllCategories() {
    printf("\n=== 所有分类 ===\n");
    for (int i = 0; i < catCount; i++)
        printf("ID: %d  名称: %s\n", categories[i].id, categories[i].name);
}

// 显示所有地点
void showAllPlaces() {
    printf("\n=== 所有地点 ===\n");
    for (int i = 0; i < placeCount; i++) {
        char catName[50] = "未知分类";
        for (int j = 0; j < catCount; j++)
            if (categories[j].id == places[i].categoryId) {
                strcpy(catName, categories[j].name);
                break;
            }
        printf("ID: %d  名称: %-15s  分类: %s\n", 
               places[i].id, places[i].name, catName);
    }
}

// 添加分类
void addCategory() {
    char name[50];
    printf("\n请输入新分类名称: ");
    scanf("%s", name);
    int newId = catCount > 0 ? categories[catCount-1].id + 1 : 1;
    categories[catCount++] = (Category){newId, ""};
    strcpy(categories[catCount-1].name, name);
    printf("添加成功，分类ID: %d\n", newId);
}

// 删除分类
void deleteCategory() {
    int id;
    showAllCategories();
    printf("\n请输入要删除的分类ID: ");
    scanf("%d", &id);
    
    for (int i = 0; i < placeCount; i++)
        if (places[i].categoryId == id) {
            printf("删除失败：该分类下还有地点。\n");
            return;
        }
    
    int index = -1;
    for (int i = 0; i < catCount; i++)
        if (categories[i].id == id) { index = i; break; }
    if (index == -1) { printf("分类不存在。\n"); return; }
    for (int i = index; i < catCount-1; i++) categories[i] = categories[i+1];
    catCount--;
    printf("删除成功。\n");
}

// 修改分类名称
void modifyCategory() {
    int id;
    showAllCategories();
    printf("\n请输入要修改的分类ID: ");
    scanf("%d", &id);
    
    int index = -1;
    for (int i = 0; i < catCount; i++)
        if (categories[i].id == id) { index = i; break; }
    if (index == -1) { printf("分类不存在。\n"); return; }
    char newName[50];
    printf("请输入新名称: ");
    scanf("%s", newName);
    strcpy(categories[index].name, newName);
    printf("修改成功。\n");
}

// 按分类筛选地点
void filterByCategory() {
    showAllCategories();
    int catId;
    printf("\n请输入分类ID筛选地点: ");
    scanf("%d", &catId);
    
    int catExist = 0;
    char catName[50];
    for (int i = 0; i < catCount; i++)
        if (categories[i].id == catId) {
            catExist = 1;
            strcpy(catName, categories[i].name);
            break;
        }
    if (!catExist) { printf("分类不存在。\n"); return; }
    
    printf("\n=== %s 下的地点 ===\n", catName);
    for (int i = 0; i < placeCount; i++)
        if (places[i].categoryId == catId)
            printf("ID: %d  名称: %s\n", places[i].id, places[i].name);
}

// 分类管理菜单
void categoryMenu() {
    int choice;
    while (1) {
        printf("\n--- 分类管理 ---\n");
        printf("1. 查看所有分类\n2. 添加分类\n3. 删除分类\n");
        printf("4. 修改分类名称\n5. 按分类筛选地点\n0. 返回主菜单\n");
        printf("请选择: ");
        scanf("%d", &choice);
        switch (choice) {
            case 1: showAllCategories(); break;
            case 2: addCategory(); break;
            case 3: deleteCategory(); break;
            case 4: modifyCategory(); break;
            case 5: filterByCategory(); break;
            case 0: return;
            default: printf("无效选择。\n");
        }
    }
}

// 主菜单
void mainMenu() {
    int choice;
    while (1) {
        printf("\n===== 校园导航系统 版本1 =====\n");
        printf("1. 查看所有地点\n2. 分类管理\n0. 退出系统\n");
        printf("请选择功能: ");
        scanf("%d", &choice);
        switch (choice) {
            case 1: showAllPlaces(); break;
            case 2: categoryMenu(); break;
            case 0: printf("退出系统。\n"); return;
            default: printf("无效输入，请重新选择。\n");
        }
    }
}

int main() {
    initData();
    mainMenu();
    return 0;
}