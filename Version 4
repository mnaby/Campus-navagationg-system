#include <stdio.h>
#include <string.h>
#include <time.h>
#include <stdlib.h>

#define MAX_CATEGORY 20
#define MAX_PLACE 50
#define MAX_HISTORY 100
#define MAX_RECENT 5

typedef struct {
    int id;
    char name[50];
} Category;

// 地点新增距离、热度属性
typedef struct {
    int id;
    char name[50];
    int categoryId;
    double distance;   // 距离校门（米）
    int hot;           // 访问热度
} Place;

typedef struct {
    int placeIds[MAX_HISTORY];
    int top;
} HistoryStack;

typedef struct {
    int placeIds[MAX_RECENT];
    int front;
    int rear;
    int size;
} RecentQueue;

Category categories[MAX_CATEGORY];
int catCount = 0;
Place places[MAX_PLACE];
int placeCount = 0;
HistoryStack historyStack;
RecentQueue recentQueue;
int currentPlaceId = -1;

void initStack() { historyStack.top = -1; }
void pushStack(int placeId) {
    if (historyStack.top < MAX_HISTORY - 1)
        historyStack.placeIds[++historyStack.top] = placeId;
}
int popStack() {
    if (historyStack.top == -1) return -1;
    return historyStack.placeIds[historyStack.top--];
}

void initQueue() {
    recentQueue.front = 0;
    recentQueue.rear = 0;
    recentQueue.size = 0;
}
void enqueueRecent(int placeId) {
    int exist = -1;
    for (int i = 0; i < recentQueue.size; i++) {
        int idx = (recentQueue.front + i) % MAX_RECENT;
        if (recentQueue.placeIds[idx] == placeId) { exist = i; break; }
    }
    if (exist != -1) {
        for (int i = exist; i < recentQueue.size - 1; i++) {
            int idx = (recentQueue.front + i) % MAX_RECENT;
            int nextIdx = (recentQueue.front + i + 1) % MAX_RECENT;
            recentQueue.placeIds[idx] = recentQueue.placeIds[nextIdx];
        }
        recentQueue.rear = (recentQueue.rear - 1 + MAX_RECENT) % MAX_RECENT;
        recentQueue.size--;
    }
    if (recentQueue.size == MAX_RECENT) {
        recentQueue.front = (recentQueue.front + 1) % MAX_RECENT;
        recentQueue.size--;
    }
    recentQueue.placeIds[recentQueue.rear] = placeId;
    recentQueue.rear = (recentQueue.rear + 1) % MAX_RECENT;
    recentQueue.size++;
}

char* getPlaceName(int placeId) {
    for (int i = 0; i < placeCount; i++)
        if (places[i].id == placeId) return places[i].name;
    return "未知地点";
}

// 浏览地点热度+1
void browsePlace(int placeId) {
    int idx = -1;
    for (int i = 0; i < placeCount; i++)
        if (places[i].id == placeId) { idx = i; break; }
    if (idx == -1) { printf("地点不存在。\n"); return; }
    
    if (currentPlaceId != -1) pushStack(currentPlaceId);
    currentPlaceId = placeId;
    places[idx].hot++;
    enqueueRecent(placeId);
    printf("\n当前位置：%s  距离: %.0f米  热度: %d\n", 
           places[idx].name, places[idx].distance, places[idx].hot);
}

void goBack() {
    int prevId = popStack();
    if (prevId == -1) { printf("没有可后退的历史记录。\n"); return; }
    currentPlaceId = prevId;
    printf("后退成功，当前位置：%s\n", getPlaceName(prevId));
}

void showRecentPlaces() {
    printf("\n=== 最近访问的地点（共%d个）===\n", recentQueue.size);
    if (recentQueue.size == 0) { printf("暂无记录。\n"); return; }
    for (int i = recentQueue.size - 1; i >= 0; i--) {
        int idx = (recentQueue.front + i) % MAX_RECENT;
        printf("%d. %s\n", recentQueue.size - i, getPlaceName(recentQueue.placeIds[idx]));
    }
}

void jumpFromRecent() {
    showRecentPlaces();
    if (recentQueue.size == 0) return;
    int num;
    printf("请输入序号跳转（输入0取消）: ");
    scanf("%d", &num);
    if (num == 0) return;
    if (num < 1 || num > recentQueue.size) { printf("无效序号。\n"); return; }
    int idx = (recentQueue.front + (recentQueue.size - num)) % MAX_RECENT;
    browsePlace(recentQueue.placeIds[idx]);
}

// 字符串匹配
int naiveMatch(char *text, char *pattern, int *pos) {
    int n = strlen(text), m = strlen(pattern);
    int count = 0;
    for (int i = 0; i <= n - m; i++) {
        int j;
        for (j = 0; j < m; j++)
            if (text[i+j] != pattern[j]) break;
        if (j == m) pos[count++] = i + 1;
    }
    return count;
}

void getNext(char *pattern, int *next) {
    int m = strlen(pattern);
    next[0] = -1;
    int i = 0, j = -1;
    while (i < m) {
        if (j == -1 || pattern[i] == pattern[j]) {
            i++; j++;
            next[i] = j;
        } else j = next[j];
    }
}

int kmpMatch(char *text, char *pattern, int *pos) {
    int n = strlen(text), m = strlen(pattern);
    int next[m+1];
    getNext(pattern, next);
    int count = 0, i = 0, j = 0;
    while (i < n) {
        if (j == -1 || text[i] == pattern[j]) {
            i++; j++;
        } else j = next[j];
        if (j == m) {
            pos[count++] = i - j + 1;
            j = next[j];
        }
    }
    return count;
}

void searchPlaces() {
    char keyword[50];
    printf("\n请输入搜索关键词: ");
    scanf("%s", keyword);
    int pos[50];
    int naiveTotal = 0, kmpTotal = 0;
    
    printf("\n--- 朴素匹配结果 ---\n");
    clock_t start1 = clock();
    for (int i = 0; i < placeCount; i++) {
        int cnt = naiveMatch(places[i].name, keyword, pos);
        if (cnt > 0) {
            printf("地点: %-15s 匹配位置: ", places[i].name);
            for (int k = 0; k < cnt; k++) printf("%d ", pos[k]);
            printf("\n");
            naiveTotal += cnt;
        }
    }
    clock_t end1 = clock();
    if (naiveTotal == 0) printf("未找到匹配地点。\n");
    printf("总匹配数: %d  耗时: %.2f ms\n", naiveTotal, (double)(end1-start1)/CLOCKS_PER_SEC*1000);
    
    printf("\n--- KMP匹配结果 ---\n");
    clock_t start2 = clock();
    for (int i = 0; i < placeCount; i++) {
        int cnt = kmpMatch(places[i].name, keyword, pos);
        if (cnt > 0) {
            printf("地点: %-15s 匹配位置: ", places[i].name);
            for (int k = 0; k < cnt; k++) printf("%d ", pos[k]);
            printf("\n");
            kmpTotal += cnt;
        }
    }
    clock_t end2 = clock();
    if (kmpTotal == 0) printf("未找到匹配地点。\n");
    printf("总匹配数: %d  耗时: %.2f ms\n", kmpTotal, (double)(end2-start2)/CLOCKS_PER_SEC*1000);
}

// ========== 新增：排序与热力图 ==========
// qsort比较函数
int cmpDistanceAsc(const void *a, const void *b) {
    Place *p1 = (Place*)a, *p2 = (Place*)b;
    return (p1->distance > p2->distance) - (p1->distance < p2->distance);
}
int cmpDistanceDesc(const void *a, const void *b) {
    Place *p1 = (Place*)a, *p2 = (Place*)b;
    return (p2->distance > p1->distance) - (p2->distance < p1->distance);
}
int cmpHotAsc(const void *a, const void *b) {
    return ((Place*)a)->hot - ((Place*)b)->hot;
}
int cmpHotDesc(const void *a, const void *b) {
    return ((Place*)b)->hot - ((Place*)a)->hot;
}

// 热度等级
char* getHotLevel(int hot) {
    if (hot >= 10) return "🔥 高热度";
    else if (hot >= 3) return "⭐ 中热度";
    else return "💡 低热度";
}

void showSortedPlaces(Place sorted[], int n) {
    printf("\n%-3s %-15s %-10s %-8s %s\n", "ID", "名称", "距离(米)", "热度", "热度等级");
    printf("--------------------------------------------\n");
    for (int i = 0; i < n; i++) {
        printf("%-3d %-15s %-10.0f %-8d %s\n", 
               sorted[i].id, sorted[i].name, sorted[i].distance, 
               sorted[i].hot, getHotLevel(sorted[i].hot));
    }
}

void sortByDistance() {
    Place temp[MAX_PLACE];
    memcpy(temp, places, sizeof(places));
    int choice;
    printf("\n1. 距离从近到远\n2. 距离从远到近\n请选择: ");
    scanf("%d", &choice);
    if (choice == 1) qsort(temp, placeCount, sizeof(Place), cmpDistanceAsc);
    else if (choice == 2) qsort(temp, placeCount, sizeof(Place), cmpDistanceDesc);
    else { printf("无效选择。\n"); return; }
    showSortedPlaces(temp, placeCount);
}

void sortByHot() {
    Place temp[MAX_PLACE];
    memcpy(temp, places, sizeof(places));
    int choice;
    printf("\n1. 热度从低到高\n2. 热度从高到低\n请选择: ");
    scanf("%d", &choice);
    if (choice == 1) qsort(temp, placeCount, sizeof(Place), cmpHotAsc);
    else if (choice == 2) qsort(temp, placeCount, sizeof(Place), cmpHotDesc);
    else { printf("无效选择。\n"); return; }
    showSortedPlaces(temp, placeCount);
}

void sortMenu() {
    int choice;
    while (1) {
        printf("\n--- 排序与热力展示 ---\n");
        printf("1. 按距离排序\n2. 按热度排序（热力图）\n0. 返回\n请选择: ");
        scanf("%d", &choice);
        switch (choice) {
            case 1: sortByDistance(); break;
            case 2: sortByHot(); break;
            case 0: return;
            default: printf("无效选择。\n");
        }
    }
}

