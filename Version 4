#include <iostream>
#include <cstring>
#include <algorithm>
#include <ctime>
using namespace std;

const int MAX_LOC = 30;
const int MAX_CAT = 10;
const int NAME_LEN = 20;
const int MAX_HISTORY = 30;
const int MAX_RECENT = 5;
const int INF = 0x3f3f3f3f;

// 分类结构体
struct Category {
    int id;
    char name[NAME_LEN];
};

// ==================== V4 核心：地点结构体扩展 ====================
// 新增：热度 hot(访问次数)、距离 dist
struct Location {
    int id;
    char name[NAME_LEN];
    int category_id;
    int hot;     // 热度 = 访问次数
    int dist;    // 距离参考点的距离
};

// 顺序表、栈、队列、图结构（保留V3）
struct LocationList { Location data[MAX_LOC]; int length; };
struct CategoryList { Category data[MAX_CAT]; int length; };
struct HistoryStack { Location data[MAX_HISTORY]; int top; };
struct RecentQueue { Location data[MAX_RECENT]; int front, rear, count; };
struct CampusGraph { int edge[MAX_LOC][MAX_LOC]; int nodeNum; };

// ==================== 图 & 最短路径 Dijkstra（V3保留） ====================
void initGraph(CampusGraph &g, int n) {
    g.nodeNum = n;
    for(int i=1; i<=n; i++) for(int j=1; j<=n; j++)
        g.edge[i][j] = (i==j) ? 0 : INF;
}
void addPath(CampusGraph &g, int a, int b, int len) { g.edge[a][b]=g.edge[b][a]=len; }
const Location* findLocationById(const LocationList &list, int id);
void dijkstra(const CampusGraph &g, const LocationList &list, int startId, int endId) {
    int dist[MAX_LOC], vis[MAX_LOC]={0}, pre[MAX_LOC];
    for(int i=1; i<=g.nodeNum; i++) dist[i]=g.edge[startId][i], pre[i]=-1;
    dist[startId]=0; vis[startId]=1;

    for(int i=2; i<=g.nodeNum; i++){
        int min=INF, u=-1;
        for(int j=1; j<=g.nodeNum; j++) if(!vis[j]&&dist[j]<min) min=dist[j],u=j;
        if(u==-1) break; vis[u]=1;
        for(int v=1; v<=g.nodeNum; v++)
            if(!vis[v]&&g.edge[u][v]!=INF&&dist[v]>dist[u]+g.edge[u][v])
                dist[v]=dist[u]+g.edge[u][v], pre[v]=u;
    }

    const Location *s=findLocationById(list,startId),*e=findLocationById(list,endId);
    cout<<"\n===== 最短路径 =====\n起点："<<s->name<<"\n终点："<<e->name<<endl;
    if(dist[endId]==INF) {cout<<"不可达"<<endl; return;}
    cout<<"总距离："<<dist[endId]<<"\n路线：";
    int path[MAX_LOC],cnt=0;
    for(int cur=endId;cur!=-1;cur=pre[cur]) path[cnt++]=cur;
    for(int i=cnt-1;i>=0;i--){
        cout<<findLocationById(list,path[i])->name;
        if(i>0) cout<<" → ";
    } cout<<endl;
}

// ==================== BF/KMP 搜索（V3保留） ====================
int BF(const char* t,const char* p){int n=strlen(t),m=strlen(p),i=0,j=0;
while(i<n&&j<m){if(t[i]==p[j])i++,j++;else i=i-j+1,j=0;}return j==m?i-j:-1;}
void buildNext(const char*p,int*next){int m=strlen(p),j=0,t=-1;next[0]=-1;
while(j<m-1){if(t==-1||p[j]==p[t])j++,t++,next[j]=t;else t=next[t];}}
int KMP(const char*t,const char*p){int n=strlen(t),m=strlen(p);
if(!m)return 0;int*next=new int[m];buildNext(p,next);int i=0,j=0;
while(i<n&&j<m){if(j==-1||t[i]==p[j])i++,j++;else j=next[j];}
delete[]next;return j==m?i-j:-1;}
void searchLocationWithAlgo(const LocationList &list,const char*key,int type){
    cout<<"\n搜索："<<key<<"("<<(type==0?"BF":"KMP")<<")\n";
    bool f=0;clock_t s=clock();
    for(int i=0;i<list.length;i++)
        if((type==0?BF:KMP)(list.data[i].name,key)!=-1)
            cout<<"- "<<list.data[i].name<<endl,f=1;
    cout<<"耗时："<<(double)(clock()-s)/CLOCKS_PER_SEC*1000<<"ms\n";
    if(!f)cout<<"无结果\n";
}

// ==================== 基础初始化函数 ====================
void initLocList(LocationList &list){list.length=0;}
void initCatList(CategoryList &list){list.length=0;}
void initHistoryStack(HistoryStack &s){s.top=-1;}
void initRecentQueue(RecentQueue &q){q.front=q.rear=q.count=0;}

bool addCategory(CategoryList &list,int id,const char*name){
    if(list.length>=MAX_CAT)return 0;
    list.data[list.length].id=id;strcpy(list.data[list.length++].name,name);return 1;
}

// 添加地点：V4 默认初始化热度=0，距离=0
bool addLocation(LocationList &list,int id,const char*name,int catId){
    if(list.length>=MAX_LOC)return 0;
    list.data[list.length].id=id;
    strcpy(list.data[list.length].name,name);
    list.data[list.length].category_id=catId;
    list.data[list.length].hot=0;    // V4
    list.data[list.length].dist=0;   // V4
    list.length++;return 1;
}

const Location* findLocationById(const LocationList &list, int id){
    for(int i=0;i<list.length;i++)if(list.data[i].id==id)return &list.data[i];
    return nullptr;
}
const char* getCategoryName(const CategoryList &cat,int id){
    for(int i=0;i<cat.length;i++)if(cat.data[i].id==id)return cat.data[i].name;
    return "未知";
}

// 打印：V4 显示 热度+距离
void printAllLocations(const LocationList &list){
    cout<<"\n=== 全部地点 ===\n";
    for(int i=0;i<list.length;i++)
        cout<<list.data[i].id<<". "<<list.data[i].name
        <<"  热度:"<<list.data[i].hot<<"  距离:"<<list.data[i].dist<<endl;
}

void filterByCategory(const LocationList &l,const CategoryList &c,int id){
    cout<<"\n【"<<getCategoryName(c,id)<<"】\n";bool f=0;
    for(int i=0;i<l.length;i++)if(l.data[i].category_id==id)
        cout<<"- "<<l.data[i].name<<endl,f=1;
    if(!f)cout<<"无地点\n";
}

// ==================== 历史栈 & 最近访问队列（V2） ====================
void pushHistory(HistoryStack &s,const Location &l){if(s.top<MAX_HISTORY-1)s.data[++s.top]=l;}
const Location* popHistory(HistoryStack &s){return s.top<0?0:&s.data[s.top--];}
void printHistory(const HistoryStack &s){cout<<"\n浏览历史\n";if(s.top<0){cout<<"无\n";return;}
for(int i=s.top;i>=0;i--)cout<<s.data[i].name<<" → ";cout<<"开始\n";}

void addToRecent(RecentQueue &q,const Location &l){
    if(q.count>=MAX_RECENT)q.front=(q.front+1)%MAX_RECENT,q.count--;
    q.rear=(q.rear+1)%MAX_RECENT;q.data[q.rear]=l;q.count++;
}
void printRecent(const RecentQueue &q){cout<<"\n最近访问\n";
int idx=q.front;for(int i=0;i<q.count;i++)cout<<q.data[idx++%MAX_RECENT].name<<endl;}

// ==================== V4 核心功能1：访问地点 → 热度+1 ====================
// 时间复杂度 O(1)
void visitLocation(HistoryStack &h,RecentQueue &r,LocationList &list,int id){
    Location* loc=(Location*)findLocationById(list,id);
    if(!loc){cout<<"不存在\n";return;}
    pushHistory(h,*loc);addToRecent(r,*loc);
    loc->hot++;  // 访问一次，热度+1
    cout<<"访问成功："<<loc->name<<" 热度："<<loc->hot<<endl;
}

// ==================== V4 核心功能2：自定义排序比较函数 ====================
// 按热度降序
bool cmpByHot(const Location &a, const Location &b) {return a.hot > b.hot;}
// 按距离升序
bool cmpByDist(const Location &a, const Location &b) {return a.dist < b.dist;}

// ==================== V4 核心功能3：排序（sort快排 O(nlogn)） ====================
void sortByHot(LocationList &list) {sort(list.data,list.data+list.length,cmpByHot);}
void sortByDistance(LocationList &list) {sort(list.data,list.data+list.length,cmpByDist);}

// ==================== V4 核心功能4：手动设置地点距离 ====================
void setDistance(LocationList &list,int id,int d){
    Location* p=(Location*)findLocationById(list,id);
    if(p)p->dist=d,cout<<"设置成功："<<p->name<<" 距离="<<d<<endl;
    else cout<<"不存在\n";
}

// ==================== V4 菜单（新增排序/设置距离） ====================
void showMenu(){
    cout<<"\n====== 校园导航系统 V4 ======\n";
    cout<<"1.查看全部地点\n2.按分类查看\n3.访问地点(热度+1)\n4.浏览历史\n5.最近访问\n";
    cout<<"6.BF搜索\n7.KMP搜索\n8.最短路径\n9.按热度降序\n10.按距离升序\n11.设置地点距离\n0.退出\n";
    cout<<"请输入：";
}

// ==================== 主函数 ====================
int main(){
    LocationList locList;CategoryList catList;
    HistoryStack history;RecentQueue recent;CampusGraph graph;

    initLocList(locList);initCatList(catList);
    initHistoryStack(history);initRecentQueue(recent);

    // 分类
    addCategory(catList,1,"教学楼");addCategory(catList,2,"食堂");
    addCategory(catList,3,"宿舍");addCategory(catList,4,"图书馆");addCategory(catList,5,"操场");

    // 地点
    addLocation(locList,1,"一号教学楼",1);addLocation(locList,2,"二号教学楼",1);
    addLocation(locList,3,"第一食堂",2);addLocation(locList,4,"第二食堂",2);
    addLocation(locList,5,"男生宿舍",3);addLocation(locList,6,"女生宿舍",3);
    addLocation(locList,7,"中心图书馆",4);addLocation(locList,8,"主操场",5);
    addLocation(locList,9,"行政楼",1);addLocation(locList,10,"校园大门",1);

    // 地图初始化
    initGraph(graph,10);
    addPath(graph,1,2,50);addPath(graph,1,3,100);addPath(graph,1,10,80);
    addPath(graph,2,4,70);addPath(graph,2,7,120);addPath(graph,3,5,60);
    addPath(graph,4,6,60);addPath(graph,5,7,90);addPath(graph,6,7,80);
    addPath(graph,7,8,150);addPath(graph,8,9,100);addPath(graph,9,10,70);

    int op;
    while(true){
        showMenu();cin>>op;
        if(op==0) {cout<<"退出成功\n";break;}
        switch(op){
            case 1:printAllLocations(locList);break;
            case 2:{int id;cout<<"分类ID：";cin>>id;filterByCategory(locList,catList,id);break;}
            case 3:{int id;cout<<"地点ID：";cin>>id;visitLocation(history,recent,locList,id);break;}
            case 4:printHistory(history);break;
            case 5:printRecent(recent);break;
            case 6:{char k[20];cout<<"关键词：";cin>>k;searchLocationWithAlgo(locList,k,0);break;}
            case 7:{char k[20];cout<<"关键词：";cin>>k;searchLocationWithAlgo(locList,k,1);break;}
            case 8:{int s,e;cout<<"起点：";cin>>s;cout<<"终点：";cin>>e;dijkstra(graph,locList,s,e);break;}
            case 9:sortByHot(locList);cout<<"已按热度降序排序\n";printAllLocations(locList);break;
            case 10:sortByDistance(locList);cout<<"已按距离升序排序\n";printAllLocations(locList);break;
            case 11:{int id,d;cout<<"地点ID：";cin>>id;cout<<"距离：";cin>>d;setDistance(locList,id,d);break;}
            default:cout<<"无效输入\n";
        }
    }
    return 0;
}
