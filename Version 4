    categories[catCount++] = (Category){2, "生活区"};
    categories[catCount++] = (Category){3, "运动区"};
    places[placeCount++] = (Place){1, "第一教学楼", 1, 200, 0};
    places[placeCount++] = (Place){2, "图书馆", 1, 350, 0};
    places[placeCount++] = (Place){3, "实验楼", 1, 500, 0};
    places[placeCount++] = (Place){4, "学生食堂", 2, 150, 0};
    places[placeCount++] = (Place){5, "学生宿舍", 2, 600, 0};
    places[placeCount++] = (Place){6, "超市", 2, 180, 0};
    places[placeCount++] = (Place){7, "体育馆", 3, 400, 0};
    places[placeCount++] = (Place){8, "田径场", 3, 450, 0};
