#include <iostream>
#include <cstring>
#include <algorithm>
using namespace std;

const int MAX_LOC = 30;
const int MAX_CAT = 10;
const int NAME_LEN = 20;
const int MAX_HISTORY = 30;
const int MAX_RECENT = 5;

// 分类
struct Category {
    int id;
    char name[NAME_LEN];
};

// 地点（V4新增：热度 hot、距离 dist）
struct Location {
    int id;
    char name[NAME_LEN];
    int category_id;
    int hot;         // 访问热度
    int dist;        // 距离参考点的距离
};

// 地点顺序表
struct LocationList {
    Location data[MAX_LOC];
    int length;
};

// 分类顺序表
struct CategoryList {
    Category data[MAX_CAT];
    int length;
};

// 浏览历史栈
struct HistoryStack {
    Location data[MAX_HISTORY];
    int top;
};

// 最近访问队列
struct RecentQueue {
    Location data[MAX_RECENT];
    int front;
    int rear;
    int count;
};

// 初始化
void initLocList(LocationList &list) {
    list.length = 0;
}

void initCatList(CategoryList &list) {
    list.length = 0;
}

void initHistoryStack(HistoryStack &stack) {
    stack.top = -1;
}

void initRecentQueue(RecentQueue &queue) {
    queue.front = 0;
    queue.rear = -1;
    queue.count = 0;
}

// 添加地点（V4：初始化热度、距离）
bool addLocation(LocationList &list, int id, const char* name, int catId) {
    if (list.length >= MAX_LOC) return false;
    list.data[list.length].id = id;
    strcpy(list.data[list.length].name, name);
    list.data[list.length].category_id = catId;
    list.data[list.length].hot = 0;
    list.data[list.length].dist = 0;
    list.length++;
    return true;
}

bool addCategory(CategoryList &list, int id, const char* name) {
    if (list.length >= MAX_CAT) return false;
    list.data[list.length].id = id;
    strcpy(list.data[list.length].name, name);
    list.length++;
    return true;
}

// 打印所有地点
void printAllLocations(const LocationList &list) {
    cout << "\n=== 全部校园地点（共" << list.length << "个）===" << endl;
    for (int i = 0; i < list.length; i++) {
        cout << list.data[i].id << ". " << list.data[i].name
             << "  热度:" << list.data[i].hot
             << "  距离:" << list.data[i].dist << endl;
    }
}

// 获取分类名称
const char* getCategoryName(const CategoryList &catList, int catId) {
    for (int i = 0; i < catList.length; i++) {
        if (catList.data[i].id == catId)
            return catList.data[i].name;
    }
    return "未知分类";
}

// 按分类筛选
void filterByCategory(const LocationList &locList, const CategoryList &catList, int catId) {
    cout << "\n=== 分类【" << getCategoryName(catList, catId) << "】===" << endl;
    bool found = false;
    for (int i = 0; i < locList.length; i++) {
        if (locList.data[i].category_id == catId) {
            cout << "- " << locList[i].name << endl;
            found = true;
        }
    }
    if (!found) cout << "该分类下暂无地点。" << endl;
}

// 按ID查找
const Location* findLocationById(const LocationList &list, int id) {
    for (int i = 0; i < list.length; i++) {
        if (list.data[i].id == id)
            return &list.data[i];
    }
    return nullptr;
}

// ==================== V2 浏览历史 ====================
void pushHistory(HistoryStack &stack, const Location &loc) {
    if (stack.top >= MAX_HISTORY - 1) return;
    stack.top++;
    stack.data[stack.top] = loc;
}

const Location* popHistory(HistoryStack &stack) {
    if (stack.top == -1) return nullptr;
    return &stack.data[stack.top--];
}

void printHistory(const HistoryStack &stack) {
    cout << "\n=== 浏览历史 ===" << endl;
    if (stack.top == -1) { cout << "无记录" << endl; return; }
    for (int i = stack.top; i >= 0; i--)
        cout << stack.data[i].name << " → ";
    cout << "开始" << endl;
}

// ==================== V2 最近访问 ====================
void addToRecent(RecentQueue &queue, const Location &loc) {
    if (queue.count >= MAX_RECENT) {
        queue.front = (queue.front + 1) % MAX_RECENT;
        queue.count--;
    }
    queue.rear = (queue.rear + 1) % MAX_RECENT;
    queue.data[queue.rear] = loc;
    queue.count++;
}

void printRecent(const RecentQueue &queue) {
    cout << "\n=== 最近访问 ===" << endl;
    int idx = queue.front;
    for (int i = 0; i < queue.count; i++) {
        cout << queue.data[idx].name << endl;
        idx = (idx + 1) % MAX_RECENT;
    }
}

// 访问地点（V4：访问一次热度+1）
void visitLocation(HistoryStack &h, RecentQueue &r, LocationList &list, int locId) {
    Location* loc = (Location*)findLocationById(list, locId);
    if (!loc) { cout << "不存在" << endl; return; }
    pushHistory(h, *loc);
    addToRecent(r, *loc);
    loc->hot++;  // 热度+1
    cout << "访问：" << loc->name << "  热度变为：" << loc->hot << endl;
}

// ==================== V3 模糊搜索 ====================
void searchLocation(const LocationList &list, const char* keyword) {
    cout << "\n=== 搜索：" << keyword << " ===" << endl;
    bool found = false;
    for (int i = 0; i < list.length; i++) {
        if (strstr(list.data[i].name, keyword)) {
            cout << "- " << list.data[i].name << endl;
            found = true;
        }
    }
    if (!found) cout << "无结果" << endl;
}

// ==================== V4 新增：热度 & 距离排序 ====================
// 按热度降序
bool cmpByHot(const Location &a, const Location &b) {
    return a.hot > b.hot;
}

// 按距离升序
bool cmpByDist(const Location &a, const Location &b) {
    return a.dist < b.dist;
}

// 按热度排序
void sortByHot(LocationList &list) {
    sort(list.data, list.data + list.length, cmpByHot);
}

// 按距离排序
void sortByDistance(LocationList &list) {
    sort(list.data, list.data + list.length, cmpByDist);
}

// 手动设置距离
void setDistance(LocationList &list, int locId, int dist) {
    Location* p = (Location*)findLocationById(list, locId);
    if (p) p->dist = dist;
}

int main() {
    LocationList locList;
    CategoryList catList;
    HistoryStack history;
    RecentQueue recent;

    initLocList(locList);
    initCatList(catList);
    initHistoryStack(history);
    initRecentQueue(recent);

    // 分类
    addCategory(catList, 1, "教学区");
    addCategory(catList, 2, "生活区");
    addCategory(catList, 3, "运动区");
    addCategory(catList, 4, "校门区");

    // 地点
    addLocation(locList, 1, "弘义楼西", 1);
    addLocation(locList, 2, "弘义楼", 1);
    addLocation(locList, 3, "弘义楼东", 1);
    addLocation(locList, 4, "明德楼", 1);
    addLocation(locList, 5, "明德楼西", 1);
    addLocation(locList, 6, "明德楼东", 1);
    addLocation(locList, 7, "图书馆", 1);
    addLocation(locList, 8, "致远楼", 1);

    addLocation(locList, 9, "今日餐厅", 2);
    addLocation(locList, 10, "1A楼", 2);
    addLocation(locList, 11, "1B楼", 2);
    addLocation(locList, 12, "2A楼", 2);
    addLocation(locList, 13, "2B楼", 2);
    addLocation(locList, 14, "3A楼", 2);
    addLocation(locList, 15, "3B楼", 2);

    addLocation(locList, 16, "体育场", 3);
    addLocation(locList, 17, "球场", 3);

    addLocation(locList, 18, "综合楼", 4);
    addLocation(locList, 19, "北门", 4);
    addLocation(locList, 20, "北二门", 4);

    // 模拟多次访问，形成热度差异
    visitLocation(history, recent, locList, 7);
    visitLocation(history, recent, locList, 7);
    visitLocation(history, recent, locList, 4);
    visitLocation(history, recent, locList, 2);
    visitLocation(history, recent, locList, 9);
    visitLocation(history, recent, locList, 16);

    // 设置距离
    setDistance(locList, 1, 120);
    setDistance(locList, 2, 100);
    setDistance(locList, 7, 180);
    setDistance(locList, 4, 150);
    setDistance(locList, 9, 300);

    // 打印
    printAllLocations(locList);

    // V3 搜索
    searchLocation(locList, "楼");

    // V4 排序测试
    cout << "\n===== 按热度从高到低 =====" << endl;
    sortByHot(locList);
    printAllLocations(locList);

    cout << "\n===== 按距离从近到远 =====" << endl;
    sortByDistance(locList);
    printAllLocations(locList);

    return 0;
